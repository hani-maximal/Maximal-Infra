# ===========================================================================
# REQUIRED — app will not start correctly without these
# ===========================================================================

PORT=4310
HOST=127.0.0.1
MAXIMAL_MODE=observe          # observe | approve | bounded_auto
CONTRACTS_DIR=contracts

# ---------------------------------------------------------------------------
# Anthropic — LLM classifier and contract learner.
# Without this the system falls back to detector-assigned confidence only.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# AWS credentials — set any one method to activate the real AWS adapter.
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
# AWS_PROFILE=my-named-profile   # alternative to key/secret above

# ---------------------------------------------------------------------------
# Slack — approval requests and outcome notifications via Socket Mode.
# All three values are required together for Slack to function.
# ---------------------------------------------------------------------------
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...

# ---------------------------------------------------------------------------
# Auth — login-gated UI and API access.
# When unset the app runs unauthenticated (safe for local dev behind a VPN).
# ---------------------------------------------------------------------------
MAXIMAL_JWT_SECRET=change-me-to-a-long-random-string
MAXIMAL_OPERATOR_USERNAME=admin
MAXIMAL_OPERATOR_PASSWORD=changeme


# ===========================================================================
# OPTIONAL — enable persistence, multi-tenancy, and advanced features
# ===========================================================================

# ---------------------------------------------------------------------------
# Postgres — audit persistence, learning pipeline, and app data.
# RDS in prod: use an IAM-authenticated connection string or
# Secrets Manager–injected DATABASE_URL. Enforces SSL for non-localhost URLs.
# Ops DB and App DB should be separate clusters (different PII retention).
# ---------------------------------------------------------------------------
# DATABASE_URL=postgres://maximal:changeme@localhost:5432/maximal
# APP_DATABASE_URL=postgres://maximal_app:changeme@localhost:5432/maximal_app

# ---------------------------------------------------------------------------
# Redis — BullMQ queues and rate limiting.
# Use rediss:// for TLS (ElastiCache in-transit encryption).
# ---------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379
# REDIS_TLS=false

# ---------------------------------------------------------------------------
# Multi-tenancy — default tenant UUID for single-tenant deployments.
# M7 multi-tenant SaaS: tenant resolved from JWT session instead.
# ---------------------------------------------------------------------------
# DEFAULT_TENANT_ID=00000000-0000-4000-8000-000000000001

# ---------------------------------------------------------------------------
# Subscription tier — controls feature gates (service count, connectors,
# custom trust configs). Overridden by the DB tenants.subscription_tier column
# when DATABASE_URL is set. Defaults to "team" when unset.
# Values: starter | team | scale | enterprise
# ---------------------------------------------------------------------------
# MAXIMAL_SUBSCRIPTION_TIER=team

# CORS — comma-separated allowed origins (production only).
# MAXIMAL_ALLOWED_ORIGINS=https://maximal.example.com

# ---------------------------------------------------------------------------
# GitHub — enables open_fix_as_code_pr action (used in 10+ contracts).
# PAT needs repo + pull_request write scope on the target infra repo.
# GitHub App (all three required together) is recommended for production.
#
# Local dev: download the .pem from the App settings page and point
#   GITHUB_PRIVATE_KEY_PATH at it — no escaping needed.
# Production (ECS): store the raw PEM in Secrets Manager and inject via
#   GITHUB_PRIVATE_KEY; ECS/Secrets Manager handles multiline natively.
# ---------------------------------------------------------------------------
# GITHUB_TOKEN=ghp_...
# GITHUB_APP_ID=123456
# GITHUB_PRIVATE_KEY_PATH=/path/to/maximal-infra-fixes.private-key.pem
# GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n..."   # prod / ECS only
# GITHUB_INSTALLATION_ID=78901234

# ---------------------------------------------------------------------------
# Stripe — billing, checkout, and subscription management (Tier 3 / GTM).
# All six values are required together for billing to function.
# STRIPE_PUBLISHABLE_KEY is used client-side (safe to expose in the browser).
# ---------------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_TEAM_MONTHLY=price_...
# STRIPE_PRICE_TEAM_ANNUAL=price_...
# STRIPE_PRICE_SCALE_ANNUAL=price_...

# ---------------------------------------------------------------------------
# S3 contract storage — per-tenant contract overrides and the
# proposal → live contract pipeline. Bucket needs versioning + CloudTrail.
# Keys: defaults/{type}.yaml and {tenantId}/{type}.yaml
# ---------------------------------------------------------------------------
# CONTRACTS_BUCKET=maximal-contracts

# ---------------------------------------------------------------------------
# HTTP health detector — polls a URL and creates an incident on repeated failure.
# ---------------------------------------------------------------------------
# MAXIMAL_HEALTH_URL=https://example.com
# MAXIMAL_HEALTH_SERVICE=example.com
# MAXIMAL_HEALTH_ENV=production
# MAXIMAL_HEALTH_INSTANCE_ID=i-0123456789abcdef0
# MAXIMAL_HEALTH_REGION=us-east-1
# MAXIMAL_HEALTH_INTERVAL_MS=30000
# MAXIMAL_HEALTH_FAIL_THRESHOLD=3

# ---------------------------------------------------------------------------
# CloudWatch Alarms detector — polls DescribeAlarms every 60s and creates
# incidents when alarms enter ALARM state. Uses ambient AWS credentials
# (same as AWS_ACCESS_KEY_ID / AWS_PROFILE above, or ECS task role in prod).
# MAXIMAL_CW_ALARM_PREFIX limits polling to alarms matching a name prefix —
# use this to scope Maximal to your prod alarms (e.g., "prod-" or "maximal-").
# ---------------------------------------------------------------------------
# MAXIMAL_CW_REGION=us-east-1
# MAXIMAL_CW_ENV=production
# MAXIMAL_CW_ALARM_PREFIX=prod-
# MAXIMAL_CW_INTERVAL_MS=60000
