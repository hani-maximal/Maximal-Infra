aws_region = "us-east-1"
name       = "maximal"

# Required. Until OIDC/Cognito is configured, use your office/VPN egress IP.
allowed_ingress_cidrs = ["203.0.113.10/32"]

maximal_mode = "observe"

# Push a unique immutable tag before applying the ECS service.
image_tag = "2026-06-25-001"

# ── Data tier ─────────────────────────────────────────────────────────────────
# All three are enabled by default. Set to false to skip a tier (e.g. local dev).
enable_database         = true
enable_redis            = true
enable_contracts_bucket = true

database_instance_class = "db.t3.micro"
redis_node_type         = "cache.t3.micro"

# Required when enable_database = true. Use a strong random string (32+ chars).
# Generate: openssl rand -base64 32
jwt_secret = "CHANGE_ME_before_apply"

# ── Optional TLS and DNS ──────────────────────────────────────────────────────
# certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/..."
# route53_zone_id = "Z0123456789ABC"
# domain_name     = "maximal.example.com"

# ── Remediation roles ─────────────────────────────────────────────────────────
# Empty means no production write path (observe mode only).
remediation_role_arns = []

# Optional: provision scoped roles now, wire them up when switching to remediate mode.
# ecs_remediation_targets = {
#   auth_api = {
#     service_arn = "arn:aws:ecs:us-east-1:123456789012:service/prod/auth-api"
#   }
# }
#
# lambda_remediation_targets = {
#   billing = {
#     function_arn = "arn:aws:lambda:us-east-1:123456789012:function:billing-handler"
#   }
# }

tags = {
  Environment = "staging"
  Owner       = "platform"
}
